# ----------------------
# WordPress publishing
# ----------------------
# Base site URL (root, not /wp-json):
WP_BASE_URL=https://course.skyedu.fun
# Alternative (supported): WP_BASE=https://course.skyedu.fun

WP_USER=your_wp_username
WP_APP_PASSWORD=your_wp_app_password
# page | post
WP_POST_TYPE=page

# WP rendering: shortcode (recommended) | raw_html (legacy)
WP_RENDER_MODE=shortcode

# ----------------------
# Quiz hosting
# ----------------------
# This MUST point to a REAL static host that serves:
#   {QUIZ_PUBLIC_BASE}/{slug}/index.html
# and the folder contains index.html + quiz.json
#
# Recommended:
#   https://quiz.skyedu.fun/quiz
# or if reverse proxy on same domain:
#   https://course.skyedu.fun/quiz
QUIZ_PUBLIC_BASE=https://quiz.skyedu.fun/quiz

# embed | link | off
# embed: show Start Quiz button + iframe
# link : show Start Quiz button only
# off  : no quiz section
QUIZ_EMBED_MODE=embed

# ----------------------
# Output paths
# ----------------------
OUTPUT_DIR=output
# Recommended font shipped with this repo:
#   assets/fonts/NotoSansCJKsc-VF.ttf
# (Variable font; works with Pillow on Windows/Linux.)
FONT_PATH=assets/fonts/NotoSansCJKsc-VF.ttf

# ----------------------
# Image backend selection
# ----------------------
# comfyui | cloudflare_flux | hf_endpoint | noop
IMG_BACKEND=cloudflare_flux
PICTURE_CARDS_TYPE=Realistic

IMG_WIDTH=768
IMG_HEIGHT=768
IMG_STEPS=4
IMG_TIMEOUT_S=180
IMG_CONCURRENCY=4
IMG_MAX_RETRIES=2

# --- ComfyUI backend ---
COMFY_URL=http://127.0.0.1:8188
COMFY_WORKFLOW=assets/comfy/workflow_api.json

# --- Cloudflare Workers AI (Flux) ---
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
CF_MODEL=@cf/black-forest-labs/flux-1-schnell

# --- Hugging Face dedicated endpoint ---
HF_IMAGE_ENDPOINT_URL=
HF_TOKEN=
HF_GUIDANCE=6

# ----------------------
# TTS
# ----------------------
SKYED_TTS_RATE=-10%
SKYED_VOICE_EN=en-US-JennyNeural
SKYED_VOICE_ZH=zh-CN-XiaoxiaoNeural
